# Database
DATABASE_URL=postgresql+asyncpg://orchestra:orchestra@localhost:5432/orchestra
DATABASE_URL_SYNC=postgresql+psycopg2://orchestra:orchestra@localhost:5432/orchestra

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development   # development | production

# Worker
WORKER_ID=worker-1
LEASE_DURATION_SECONDS=30
HEARTBEAT_INTERVAL_SECONDS=10
REAPER_INTERVAL_SECONDS=5
CLAIM_BATCH_SIZE=1

# Security
MAX_TASK_PAYLOAD_BYTES=262144   # 256 KB
MAX_RETRY_ATTEMPTS_DEFAULT=10

# Chaos / demo
REHEARSAL_MODE_ENABLED=false    # set true in dev to allow kill-worker endpoint
